# =============================================================================
# layerlane-apply — environment template
# =============================================================================
# Copy to the Next.js app (gitignored):
#   cp .env.example apps/web/.env.local
#
# Or from apps/web:  cp .env.example .env.local
#
# Vercel: Project → Settings → Environment Variables (same keys).
# =============================================================================

# --- Supabase (Dashboard → Project Settings → API) ---

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI ---

OPENAI_API_KEY=

# --- App URL ---

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (Vercel): https://layerlane-apply.vercel.app
