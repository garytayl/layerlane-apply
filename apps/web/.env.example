# =============================================================================
# layerlane-apply — Next.js web app
# =============================================================================
# Copy to .env.local in this directory (gitignored):
#   cp .env.example .env.local
#
# Vercel: Project → Settings → Environment Variables (same keys for Production).
# =============================================================================

# --- Supabase (Dashboard → Project Settings → API) ---

# Project URL (public).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# anon / public key (public; bundled for browser Supabase client).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key (SECRET — server only). Used when validating API tokens from the
# browser extension and for service-role queries. Never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI ---

# Required for POST /api/jobs/[id]/analyze and dashboard “Re-analyze”.
OPENAI_API_KEY=

# --- App URL ---

# Site origin for auth callbacks and signup email redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://layerlane-apply.vercel.app
